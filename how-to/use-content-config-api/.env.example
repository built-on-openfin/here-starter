# Copy this file to `.env` and fill in your values. `.env` is git-ignored.
#
#   cp .env.example .env
#
# Both the guided UI and the sync script read from here. The UI's values are
# baked into the bundle at build time, so re-run `npm run build` (or
# `npm run start`, which builds first) after changing them.

# Your HERE domain, no trailing slash.
BASE_URL=https://my-org.here.io

# --- Authentication ---
#
# An API JWT (bearer token) issued for your org. This is the recommended
# credential and the only one the browser UI can use — a browser cannot send
# the session cookie cross-origin, whereas a bearer token passes the API's CORS
# policy. How tokens are issued depends on your org's authentication setup; ask
# your HERE administrator for one. Treat it as a secret.
HERE_API_JWT=

# The id of the authentication provider to validate against, sent as the
# x-of-auth-id header. Required only when your org has more than one provider.
HERE_AUTH_ID=

# A here-session cookie value — an alternative for the sync script only (Node),
# never the browser UI. Copy it while logged into the Admin Console: developer
# tools -> Application -> Cookies -> here-session.
# HERE_SESSION=

# --- Coming soon: server-to-server OAuth (client-credentials) ---
#
# A forward-looking path (see OAuthClientCredentialsAuth in shared/src/auth.ts).
# Standard OAuth 2.0: the script exchanges a client id/secret for a short-lived
# token. Not accepted by the API yet, and server/CI only — the client secret
# must never ship in a browser bundle.
# HERE_OAUTH_TOKEN_URL=
# HERE_OAUTH_CLIENT_ID=
# HERE_OAUTH_CLIENT_SECRET=
# HERE_OAUTH_SCOPE=
