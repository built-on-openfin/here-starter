{
	"$schema": "https://resources.here.io/schemas/agents/v1.0/custom-agent.json",
	"type": "custom",
	"url": "http://localhost:8080/agent-search.html",
	"title": "Help",
	"description": "Allows the search for help content.",
	"icon": "data:image/jpg;base64,",
	"features": {
		"search": {
			"filters": [],
			"supportsPaging": false
		}
	},
	"configurationFields": [
		{
			"name": "primaryHelpUrl",
			"title": "Primary Help JSON Url",
			"placeholder": "Enter a url to a JSON file that follows the structure of a search index."
		},
		{
			"name": "secondaryHelpUrl",
			"title": "Secondary Help JSON Url",
			"placeholder": "Enter a url to a JSON file that follows the structure of a search index.",
			"defaultValue": "N/A"
		},
		{
			"name": "tertiaryHelpUrl",
			"title": "Tertiary Help JSON Url",
			"placeholder": "Enter a url to a JSON file that follows the structure of a search index.",
			"defaultValue": "N/A"
		},
		{
			"name": "quaternaryHelpUrl",
			"title": "Quaternary Help JSON Url",
			"placeholder": "Enter a url to a JSON file that follows the structure of a search index.",
			"defaultValue": "N/A"
		}
	]
}
